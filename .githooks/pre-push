#!/usr/bin/env sh
set -eu

if [ "${SKIP_DOTFILES_PREPUSH:-0}" = "1" ]; then
  echo "Skipping dotfiles pre-push checks (SKIP_DOTFILES_PREPUSH=1)"
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

echo "Running dotfiles install idempotency check..."
python3 install.py --verify-idempotent

echo "Checking tmux setup helper stays structural..."
if grep -E 'send-keys|capture-pane|gt status|git status|shell-timeout|wait_for_shell|printf .+__tmux_setup_ready_|run_tmux .*(nvim|vim)' tmux/.tmux-setup-sessions.sh >/dev/null; then
  echo "tmux setup helper should only create sessions/windows, not launch apps or probe panes." >&2
  exit 1
fi

echo "Checking tmux palette covers all @solarized_* uses in conf..."
bash tests/tmux-colors-sync.test.sh

if command -v shellcheck >/dev/null 2>&1; then
  echo "Running shellcheck on tmux scripts..."
  shellcheck tmux/.tmux.conf 2>/dev/null || true
  for script in tmux/.tmux-*.sh tests/*.sh; do
    shellcheck "$script"
  done
else
  echo "shellcheck not found; skipping shell lint (install it for local linting)"
fi

if command -v tmux >/dev/null 2>&1; then
  echo "Running tmux script tests..."
  for test in tests/*.test.sh; do
    [ -e "$test" ] || continue
    echo "  $test"
    bash "$test"
  done
else
  echo "tmux not found; skipping tmux script tests"
fi
