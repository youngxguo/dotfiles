{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux-ai-state.sh thinking"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux-ai-state.sh idle"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux-ai-state.sh clear"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
