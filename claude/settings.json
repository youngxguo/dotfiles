{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0,
    "refreshInterval": 60
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "~/.tmux-ai-state.sh thinking" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "~/.tmux-ai-state.sh idle" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "~/.tmux-ai-state.sh clear" }] }
    ]
  }
}
