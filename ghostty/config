font-family = "MesloLGS Nerd Font Mono"
# Needed for Neovim UI glyphs (Heirline separators/icons, devicons, etc.)
font-size = 16
theme = "solarized_dark"
cursor-style = block
shell-integration-features = no-cursor
custom-shader = ./shaders/cursor-smear-fade.glsl
custom-shader-animation = true
clipboard-paste-protection = false
desktop-notifications = true

# Send Option-Enter as Meta-Enter so tmux can distinguish it from Ctrl-J.
keybind = alt+enter=text:\x1b\x0d

# Cmd 1-9: jump to the Nth tmux session. macOS/Ghostty owns Cmd, so we forward
# these as private "ESC [ n z" sequences that tmux picks up as user-keys and
# routes to the session-switch helper (see tmux/.tmux.conf, tmux/.tmux-sidebar.sh).
# Ghostty's goto_tab default binds BOTH trigger forms for each digit: the physical
# key (super+digit_N) and the translated char (super+N). A Cmd-N press can resolve
# to either, so we MUST override both — leaving one as the default lets goto_tab
# (a no-op with a single tab) swallow the press and nothing reaches tmux.
keybind = super+digit_1=text:\x1b[1z
keybind = super+1=text:\x1b[1z
keybind = super+digit_2=text:\x1b[2z
keybind = super+2=text:\x1b[2z
keybind = super+digit_3=text:\x1b[3z
keybind = super+3=text:\x1b[3z
keybind = super+digit_4=text:\x1b[4z
keybind = super+4=text:\x1b[4z
keybind = super+digit_5=text:\x1b[5z
keybind = super+5=text:\x1b[5z
keybind = super+digit_6=text:\x1b[6z
keybind = super+6=text:\x1b[6z
keybind = super+digit_7=text:\x1b[7z
keybind = super+7=text:\x1b[7z
keybind = super+digit_8=text:\x1b[8z
keybind = super+8=text:\x1b[8z
keybind = super+digit_9=text:\x1b[9z
keybind = super+9=text:\x1b[9z
